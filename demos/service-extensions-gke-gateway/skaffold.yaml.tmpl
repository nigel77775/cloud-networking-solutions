apiVersion: skaffold/v4beta13
kind: Config
metadata:
  name: legacy-dms

build:
  tagPolicy:
    inputDigest: {}
  artifacts:
    - image: us-central1-docker.pkg.dev/${PROJECT_ID}/gateway-docker/legacy-dms
      context: src/legacy-dms
      docker:
        dockerfile: Dockerfile
  googleCloudBuild:
    projectId: ${PROJECT_ID}
    region: us-central1

manifests:
  kustomize:
    paths:
      - k8s/legacy-dms

portForward:
  - resourceType: deployment
    resourceName: legacy-dms
    port: 8080
    localPort: 8081

