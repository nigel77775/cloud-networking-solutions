resource "google_project_iam_member" "ksa_roles" {
  for_each = toset(var.roles)

  project = var.project_id
  role    = each.value
  member  = "principal://iam.googleapis.com/projects/${var.project_number}/locations/global/workloadIdentityPools/${var.project_id}.svc.id.goog/subject/ns/${var.k8s_namespace}/sa/${var.k8s_service_account}"
}
