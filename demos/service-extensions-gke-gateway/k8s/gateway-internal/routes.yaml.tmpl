# legacy-dms HTTP to HTTPS redirect
apiVersion: gateway.networking.k8s.io/v1
kind: HTTPRoute
metadata:
    name: legacy-dms-redirect
    labels:
        app.kubernetes.io/name: internal-gateway
        app.kubernetes.io/component: http-redirect
spec:
    parentRefs:
        - name: internal-gateway
          sectionName: http
    hostnames:
        - "dms.internal.${BASE_DOMAIN}"
    rules:
        - filters:
              - type: RequestRedirect
                requestRedirect:
                    scheme: https
                    statusCode: 301
---
# legacy-dms backend route (host-based: dms.internal.${BASE_DOMAIN})
apiVersion: gateway.networking.k8s.io/v1
kind: HTTPRoute
metadata:
    name: legacy-dms-route
    labels:
        app.kubernetes.io/name: internal-gateway
        app.kubernetes.io/component: legacy-dms
spec:
    parentRefs:
        - name: internal-gateway
          sectionName: https
    hostnames:
        - "dms.internal.${BASE_DOMAIN}"
    rules:
        - matches:
              - path:
                    type: PathPrefix
                    value: /mcp
          backendRefs:
              - name: legacy-dms-svc
                port: 8080
---
# income-verification-api HTTP to HTTPS redirect
