---
# income-verification-api backend route (host-based: income-verification.internal.${BASE_DOMAIN})
apiVersion: gateway.networking.k8s.io/v1
kind: HTTPRoute
metadata:
    name: income-verification-api-route
    labels:
        app.kubernetes.io/name: internal-gateway
        app.kubernetes.io/component: income-verification-api
spec:
    parentRefs:
        - name: internal-gateway
          sectionName: https
    hostnames:
        - "income-verification.internal.${BASE_DOMAIN}"
    rules:
        - matches:
              - path:
                    type: PathPrefix
                    value: /api/income-verification
          backendRefs:
              - name: income-verification-api-svc
                port: 8080
        - matches:
              - path:
                    type: PathPrefix
                    value: /mcp
          backendRefs:
              - name: income-verification-api-svc
                port: 8080
---
