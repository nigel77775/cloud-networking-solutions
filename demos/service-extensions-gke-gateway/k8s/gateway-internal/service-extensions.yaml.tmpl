apiVersion: networking.gke.io/v1
kind: GCPTrafficExtension
metadata:
    name: gateway-security-extensions
spec:
    targetRefs:
        - group: "gateway.networking.k8s.io"
          kind: Gateway
          name: internal-gateway
    extensionChains:
        - name: pii-redaction-and-safety
          matchCondition:
              celExpressions:
                  - celMatcher: request.host == "dms.internal.${BASE_DOMAIN}" || request.host == "income-verification.internal.${BASE_DOMAIN}"
          extensions:
              - name: model-armor
                googleAPIServiceName: modelarmor.us-central1.rep.googleapis.com
                timeout: "500ms"
                supportedEvents:
                    - RequestHeaders
                    - RequestBody
                    - ResponseHeaders
                    - ResponseBody
                    - RequestTrailers
                    - ResponseTrailers
                metadata:
                    model_armor_settings: |
                        [
                          {
                            "model": "default",
                            "user_prompt_template_id": "projects/${PROJECT_ID}/locations/us-central1/templates/default-safety-template",
                            "model_response_template_id": "projects/${PROJECT_ID}/locations/us-central1/templates/default-safety-template"
                          }
                        ]
                failOpen: false
              - name: pii-redaction
                authority: "dlp-ext-proc-svc"
                timeout: 10s
                backendRef:
                    group: ""
                    kind: Service
                    name: dlp-ext-proc-svc
                    port: 443
                failOpen: true
                supportedEvents:
                    - RequestHeaders
                    - ResponseHeaders
                    - ResponseBody
        - name: safety-screening
          matchCondition:
              celExpressions:
                  - celMatcher: request.host.endsWith("${BASE_DOMAIN}") && !(request.host == "dms.internal.${BASE_DOMAIN}" || request.host == "income-verification.internal.${BASE_DOMAIN}")
          extensions:
              - name: model-armor
                googleAPIServiceName: modelarmor.us-central1.rep.googleapis.com
                timeout: "500ms"
                supportedEvents:
                    - RequestHeaders
                    - RequestBody
                    - ResponseHeaders
                    - ResponseBody
                    - RequestTrailers
                    - ResponseTrailers
                metadata:
                    model_armor_settings: |
                        [
                          {
                            "model": "default",
                            "user_prompt_template_id": "projects/${PROJECT_ID}/locations/us-central1/templates/default-safety-template",
                            "model_response_template_id": "projects/${PROJECT_ID}/locations/us-central1/templates/default-safety-template"
                          }
                        ]
                failOpen: false
