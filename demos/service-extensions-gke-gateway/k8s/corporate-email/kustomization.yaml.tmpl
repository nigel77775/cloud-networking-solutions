apiVersion: kustomize.config.k8s.io/v1beta1
kind: Kustomization

namespace: default

resources:
    - service-account.yaml
    - deployment.yaml
    - service.yaml

images:
    - name: corporate-email
      newName: us-central1-docker.pkg.dev/${PROJECT_ID}/gateway-docker/corporate-email
      newTag: latest

labels:
    - pairs:
          app.kubernetes.io/part-of: corporate-email
          app.kubernetes.io/managed-by: kustomize
      includeSelectors: false
