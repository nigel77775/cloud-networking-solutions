# GKE Inference Gateway - Root Kustomization Template
#
# Generated by deploy.sh using envsubst. Do not edit directly.
#
# Required environment variables:
#   RESOURCES_BLOCK      - Multiline YAML resource list (model directories)
#   COMPONENTS_BLOCK     - Multiline YAML components list (features) or empty
#   GATEWAY_HOST         - Gateway hostname (e.g., gateway.internal.example.com)
#   PROJECT_ID           - GCP project ID
#   REGION               - GCP region
#   STATIC_IP_NAME       - Name of the GKE gateway static IP
#   APIGEE_ENV           - Apigee environment name
#   MODEL_ARMOR_TEMPLATE - Full Model Armor template resource path
#   SEMANTIC_PROXY_NAME  - Apigee semantic cache proxy name
#   VPC_NAME             - VPC network name (e.g., inference-vpc)
#   SUBNET_NAME          - Primary subnet name (e.g., gke-subnet-us-central1)
apiVersion: kustomize.config.k8s.io/v1beta1
kind: Kustomization

resources:
  - base
  - gateway
${RESOURCES_BLOCK}
${COMPONENTS_BLOCK}
configMapGenerator:
  - name: gateway-env-config
    literals:
      - DNS_HOSTNAME=${GATEWAY_HOST}
      - PROJECT_ID=${PROJECT_ID}
      - STATIC_IP_NAME=${STATIC_IP_NAME}
      - REGION=${REGION}
      - APIGEE_ENV=${APIGEE_ENV}
      - MODEL_ARMOR_TEMPLATE=${MODEL_ARMOR_TEMPLATE}
      - SEMANTIC_PROXY_NAME=${SEMANTIC_PROXY_NAME}
      - VPC_NETWORK=projects/${PROJECT_ID}/global/networks/${VPC_NAME}
      - VPC_SUBNET=projects/${PROJECT_ID}/regions/${REGION}/subnetworks/${SUBNET_NAME}
    options:
      disableNameSuffixHash: true

# Patch the SecretProviderClass with the correct project ID
# (Replacements don't work well with YAML-in-string fields)
patches:
  - target:
      kind: SecretProviderClass
      name: hf-secret-provider
    patch: |-
      - op: replace
        path: /spec/parameters/secrets
        value: |
          - resourceName: "projects/${PROJECT_ID}/secrets/huggingface-token/versions/latest"
            path: "hf_api_token.txt"

replacements:
  - source:
      kind: ConfigMap
      name: gateway-env-config
      fieldPath: data.DNS_HOSTNAME
    targets:
      - select:
          kind: HTTPRoute
        fieldPaths:
          - spec.hostnames.0

  - source:
      kind: ConfigMap
      name: gateway-env-config
      fieldPath: data.STATIC_IP_NAME
    targets:
      - select:
          kind: Gateway
          name: unified-inference-gateway
        fieldPaths:
          - metadata.annotations.[networking.gke.io/static-ip]
          - spec.addresses.0.value

  - source:
      kind: ConfigMap
      name: gateway-env-config
      fieldPath: data.PROJECT_ID
    targets:
      - select:
          kind: ConfigMap
          name: model-config
        fieldPaths:
          - data.PROJECT_ID
