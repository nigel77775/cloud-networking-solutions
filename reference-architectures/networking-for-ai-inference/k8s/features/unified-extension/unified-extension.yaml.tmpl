# GCPTrafficExtension - Unified extension for semantic cache and Model Armor
#
# Generated by deploy.sh using envsubst. Do not edit directly.
#
# Required environment variables:
#   REGION               - GCP region (e.g., us-east4)
#   PROJECT_ID           - GCP project ID
#   MODEL_ARMOR_TEMPLATE - Full Model Armor template resource path
#   SEMANTIC_PROXY_NAME  - Apigee semantic cache proxy name
apiVersion: networking.gke.io/v1
kind: GCPTrafficExtension
metadata:
    name: unified-apim-extension
    namespace: default
spec:
    targetRefs:
        - group: "gateway.networking.k8s.io"
          kind: Gateway
          name: unified-inference-gateway
    extensionChains:
        # Chain 1: Semantic Cache for /cache/ path
        - name: chain-semantic-cache
          matchCondition:
              celExpressions:
                  - celMatcher: request.path.startsWith("/cache/")
          extensions:
              - name: extension-apigee-cache
                metadata:
                    # This MUST match the name of the proxy in Apigee
                    apigee-extension-processor: ${SEMANTIC_PROXY_NAME}
                    apigee-request-body: "true"
                    apigee-response-body: "true"
                failOpen: false
                timeout: 10s
                requestBodySendMode: FullDuplexStreamed
                responseBodySendMode: FullDuplexStreamed
                supportedEvents:
                    - RequestHeaders
                    - RequestBody
                    - RequestTrailers
                    - ResponseHeaders
                    - ResponseBody
                    - ResponseTrailers
                backendRef:
                    group: apim.googleapis.com
                    kind: ApigeeBackendService
                    name: apigee-cache-backend
                    port: 443
        # Chain 2: Model Armor for /security/ path
        - name: chain-model-armor
          matchCondition:
              celExpressions:
                  - celMatcher: request.path.startsWith("/security/")
          extensions:
              - name: extension-model-armor
                googleAPIServiceName: modelarmor.${REGION}.rep.googleapis.com
                timeout: 5s
                failOpen: false
                supportedEvents:
                    - RequestHeaders
                    - RequestBody
                    - RequestTrailers
                    - ResponseHeaders
                    - ResponseBody
                    - ResponseTrailers
                metadata:
                    model_armor_settings: |
                        [
                          {
                            "model": "google/gemma-3-27b-it",
                            "model_response_template_id": "${MODEL_ARMOR_TEMPLATE}",
                            "user_prompt_template_id": "${MODEL_ARMOR_TEMPLATE}"
                          }
                        ]
